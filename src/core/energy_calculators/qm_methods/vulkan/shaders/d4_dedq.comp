#version 450
#extension GL_ARB_gpu_shader_fp64 : enable
// In-SCF GFN2 D4 atom-potential dE_D4/dq (Stage 5, Part B2). One invocation per atom i:
// a GATHER over j≠i (each atom sums its own half of the symmetric pair contribution → no
// FP64 atomics, which RADV lacks). Verbatim math from the CUDA k_d4_dedq / the rocm port:
//   r4r2ij = 3·sqrtZr4r2_i·sqrtZr4r2_j ; R0 = a1·√r4r2ij + a2
//   disp_sum = s6/(r⁶+R0⁶) + s8·r4r2ij/(r⁸+R0⁸)              (BJ, geometry-fixed)
//   dc6/dq_i = ΣΣ dWq_i[a]·W_j[b]·c6ref(ei,ej,a,b)            (7×7 contraction)
//   dEdq(i) += −dc6/dq_i · disp_sum
// Mirrors D4Evaluator::computeEnergyAndGradient's per-reference path + contractC6Gfn2.
// Claude Generated (Stage 5, Part B2).
layout(local_size_x = 64) in;
layout(std430, binding = 0) readonly buffer B0 { int    Zelem[]; };      // nat (atomic number)
layout(std430, binding = 1) readonly buffer B1 { int    nref[]; };       // nat (# references)
layout(std430, binding = 2) readonly buffer B2 { double sqrtZr4r2[]; };  // nat
layout(std430, binding = 3) readonly buffer B3 { double xyz[]; };        // 3·nat (Bohr)
layout(std430, binding = 4) readonly buffer B4 { double c6[]; };         // 118²·7² element refs
layout(std430, binding = 5) readonly buffer B5 { double W[]; };          // nat·7 (ref weights)
layout(std430, binding = 6) readonly buffer B6 { double dWq[]; };        // nat·7 (∂W/∂q)
layout(std430, binding = 7) readonly buffer B7 { double params[]; };     // s6,s8,a1,a2,cut2
layout(std430, binding = 8)          buffer B8 { double dEdq[]; };        // nat (output)
layout(push_constant) uniform PC { uint nat; } pc;

const int MAX_ELEM = 118;
const int MAX_REF  = 7;

void main()
{
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.nat) return;
    int ei  = Zelem[i] - 1;
    int nri = nref[i];
    if (ei < 0 || ei >= MAX_ELEM || nri <= 0) { dEdq[i] = 0.0lf; return; }
    double s6 = params[0], s8 = params[1], a1 = params[2], a2 = params[3], cut2 = params[4];
    double xi = xyz[3u*i+0u], yi = xyz[3u*i+1u], zi = xyz[3u*i+2u];
    double sq_i = sqrtZr4r2[i];
    uint dWqi = i * uint(MAX_REF);

    double acc = 0.0lf;
    for (uint j = 0u; j < pc.nat; ++j) {
        if (j == i) continue;
        double dx = xi - xyz[3u*j+0u];
        double dy = yi - xyz[3u*j+1u];
        double dz = zi - xyz[3u*j+2u];
        double r2 = dx*dx + dy*dy + dz*dz;
        if (r2 > cut2 || r2 < 1.0e-20lf) continue;
        int ej  = Zelem[j] - 1;
        int nrj = nref[j];
        if (ej < 0 || ej >= MAX_ELEM || nrj <= 0) continue;

        double r4r2ij = 3.0lf * sq_i * sqrtZr4r2[j];
        double r0   = a1 * sqrt(r4r2ij) + a2;
        double r0_2 = r0 * r0;
        double r0_6 = r0_2 * r0_2 * r0_2;
        double r0_8 = r0_6 * r0_2;
        double r6 = r2 * r2 * r2;
        double r8 = r6 * r2;
        double t6 = 1.0lf / (r6 + r0_6);
        double t8 = 1.0lf / (r8 + r0_8);
        double disp_sum = s6 * t6 + s8 * r4r2ij * t8;

        uint Wj   = j * uint(MAX_REF);
        uint base = (uint(ei) * uint(MAX_ELEM) + uint(ej)) * uint(MAX_REF) * uint(MAX_REF);
        double dc6dqi = 0.0lf;
        for (int a = 0; a < nri; ++a) {
            double dwa = dWq[dWqi + uint(a)];
            if (dwa == 0.0lf) continue;
            uint basea = base + uint(a) * uint(MAX_REF);
            double s = 0.0lf;
            for (int b = 0; b < nrj; ++b) s += W[Wj + uint(b)] * c6[basea + uint(b)];
            dc6dqi += dwa * s;
        }
        acc += -dc6dqi * disp_sum;
    }
    dEdq[i] = acc;
}
