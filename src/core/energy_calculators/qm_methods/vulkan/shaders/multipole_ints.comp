#version 450
#extension GL_ARB_gpu_shader_fp64 : enable
#extension GL_GOOGLE_include_directive : enable
#include "vk_integrals.glsl"
// GFN2 AO multipole integrals dp_int(3)/qp_int(6) on device (Stage 3m / V-AP2). One
// thread per AO pair (mu,nu): global-origin dipole/quadrupole (cgto_multipole) then the
// per-column origin shift (origin = atom of column AO nu) + traceless transform using
// the resident overlap S. Verbatim port of CUDA k_multipole_ints + d_cgto_multipole
// (xtb_multipole.cpp setupMultipole steps 1-2). s/p only; quadrupole order xx,xy,yy,xz,
// yz,zz. dp_int contiguous 3*nn, qp_int 6*nn, column-major (mu,nu) at mu+nu*nao; NOT
// symmetric. Claude Generated.
layout(local_size_x = 8, local_size_y = 8) in;
layout(std430, binding = 0)  readonly  buffer B0  { int    ao2sh[]; };
layout(std430, binding = 1)  readonly  buffer B1  { int    ao2at[]; };
layout(std430, binding = 2)  readonly  buffer B2  { int    iao_sh[]; };
layout(std430, binding = 3)  readonly  buffer B3  { int    ang_sh[]; };
layout(std430, binding = 4)  readonly  buffer B4  { int    sh_nprim[]; };
layout(std430, binding = 5)  readonly  buffer B5  { int    sh_prim_off[]; };
layout(std430, binding = 6)  readonly  buffer B6  { double prim_alpha[]; };
layout(std430, binding = 7)  readonly  buffer B7  { double prim_coeff[]; };
layout(std430, binding = 8)  readonly  buffer B8  { double xyz[]; };
layout(std430, binding = 9)  readonly  buffer B9  { double S[]; };
layout(std430, binding = 10) writeonly buffer B10 { double dp_int[]; };
layout(std430, binding = 11) writeonly buffer B11 { double qp_int[]; };
layout(push_constant) uniform PC { uint nao; } pc;

void type_to_cart(int t, out int lx, out int ly, out int lz) {
    lx = 0; ly = 0; lz = 0;
    if (t == 1) lx = 1; else if (t == 2) ly = 1; else if (t == 3) lz = 1;
}

// 1-D moment integral, la,lb in {0,1}, n in {0,1,2}. M0=sqrt(pi/g), M2=M0/(2g), M4=3M0/(4g²).
double moment1d(int la, int lb, int n, double PA, double PB, double P, double gamma) {
    double a0 = (la == 0) ? 1.0lf : PA;
    double a1 = (la == 0) ? 0.0lf : 1.0lf;
    double b0 = (lb == 0) ? 1.0lf : PB;
    double b1 = (lb == 0) ? 0.0lf : 1.0lf;
    double p0, p1, p2;
    if (n == 0)      { p0 = 1.0lf;  p1 = 0.0lf;     p2 = 0.0lf; }
    else if (n == 1) { p0 = P;      p1 = 1.0lf;     p2 = 0.0lf; }
    else             { p0 = P * P;  p1 = 2.0lf * P; p2 = 1.0lf; }
    double ab0 = a0 * b0;
    double ab1 = a0 * b1 + a1 * b0;
    double ab2 = a1 * b1;
    double c0 = ab0 * p0;
    double c2 = ab0 * p2 + ab1 * p1 + ab2 * p0;
    double c4 = ab2 * p2;
    double M0 = sqrt(VK_PI / gamma);
    double M2 = M0 / (2.0lf * gamma);
    double M4 = 3.0lf * M0 / (4.0lf * gamma * gamma);
    return c0 * M0 + c2 * M2 + c4 * M4;
}

// Primitive overlap + dipole(3) + raw-Cartesian quadrupole(6), global origin.
void primitive_multipole(double aa, double ab, double Ax, double Ay, double Az,
                         double Bx, double By, double Bz, int ta, int tb,
                         out double S0, out double D0, out double D1, out double D2,
                         out double Q0, out double Q1, out double Q2,
                         out double Q3, out double Q4, out double Q5) {
    int lxa, lya, lza, lxb, lyb, lzb;
    type_to_cart(ta, lxa, lya, lza);
    type_to_cart(tb, lxb, lyb, lzb);
    double gamma = aa + ab;
    double Px = (aa * Ax + ab * Bx) / gamma;
    double Py = (aa * Ay + ab * By) / gamma;
    double Pz = (aa * Az + ab * Bz) / gamma;
    double dx = Ax - Bx, dy = Ay - By, dz = Az - Bz;
    double R2 = dx*dx + dy*dy + dz*dz;
    double K = dexp(-aa * ab / gamma * R2);
    double PAx = Px - Ax, PAy = Py - Ay, PAz = Pz - Az;
    double PBx = Px - Bx, PBy = Py - By, PBz = Pz - Bz;
    double Sx0 = moment1d(lxa, lxb, 0, PAx, PBx, Px, gamma);
    double Sy0 = moment1d(lya, lyb, 0, PAy, PBy, Py, gamma);
    double Sz0 = moment1d(lza, lzb, 0, PAz, PBz, Pz, gamma);
    double Sx1 = moment1d(lxa, lxb, 1, PAx, PBx, Px, gamma);
    double Sy1 = moment1d(lya, lyb, 1, PAy, PBy, Py, gamma);
    double Sz1 = moment1d(lza, lzb, 1, PAz, PBz, Pz, gamma);
    double Sx2 = moment1d(lxa, lxb, 2, PAx, PBx, Px, gamma);
    double Sy2 = moment1d(lya, lyb, 2, PAy, PBy, Py, gamma);
    double Sz2 = moment1d(lza, lzb, 2, PAz, PBz, Pz, gamma);
    S0 = K * Sx0 * Sy0 * Sz0;
    D0 = K * Sx1 * Sy0 * Sz0;
    D1 = K * Sx0 * Sy1 * Sz0;
    D2 = K * Sx0 * Sy0 * Sz1;
    Q0 = K * Sx2 * Sy0 * Sz0;  // xx
    Q1 = K * Sx1 * Sy1 * Sz0;  // xy
    Q2 = K * Sx0 * Sy2 * Sz0;  // yy
    Q3 = K * Sx1 * Sy0 * Sz1;  // xz
    Q4 = K * Sx0 * Sy1 * Sz1;  // yz
    Q5 = K * Sx0 * Sy0 * Sz2;  // zz
}

void main()
{
    uint mu = gl_GlobalInvocationID.x;
    uint nu = gl_GlobalInvocationID.y;
    if (mu >= pc.nao || nu >= pc.nao) return;
    uint n = pc.nao;
    uint nn = n * n;
    uint mn = mu + nu * n;

    for (uint k = 0u; k < 3u; ++k) dp_int[k * nn + mn] = 0.0lf;
    for (uint k = 0u; k < 6u; ++k) qp_int[k * nn + mn] = 0.0lf;

    int isha = ao2sh[mu], iat = ao2at[mu];
    int ishb = ao2sh[nu], jat = ao2at[nu];
    int ta = ao_to_type(ang_sh[isha], int(mu) - iao_sh[isha]);
    int tb = ao_to_type(ang_sh[ishb], int(nu) - iao_sh[ishb]);
    if (ta < 0 || tb < 0) return;

    int offa = sh_prim_off[isha], npa = sh_nprim[isha];
    int offb = sh_prim_off[ishb], npb = sh_nprim[ishb];
    double xa = xyz[3*iat+0], ya = xyz[3*iat+1], za = xyz[3*iat+2];
    double xb = xyz[3*jat+0], yb = xyz[3*jat+1], zb = xyz[3*jat+2];

    // Contracted global-origin overlap + dipole + raw quadrupole.
    double Sx = 0.0lf, D0 = 0.0lf, D1 = 0.0lf, D2 = 0.0lf;
    double Q0 = 0.0lf, Q1 = 0.0lf, Q2 = 0.0lf, Q3 = 0.0lf, Q4 = 0.0lf, Q5 = 0.0lf;
    for (int i = 0; i < npa; ++i) {
        double ai = prim_alpha[offa + i], ci = prim_coeff[offa + i];
        for (int j = 0; j < npb; ++j) {
            double aj = prim_alpha[offb + j], cj = prim_coeff[offb + j];
            double s, d0, d1, d2, q0, q1, q2, q3, q4, q5;
            primitive_multipole(ai, aj, xa, ya, za, xb, yb, zb, ta, tb,
                                s, d0, d1, d2, q0, q1, q2, q3, q4, q5);
            double cc = ci * cj;
            Sx += cc * s;
            D0 += cc * d0; D1 += cc * d1; D2 += cc * d2;
            Q0 += cc * q0; Q1 += cc * q1; Q2 += cc * q2;
            Q3 += cc * q3; Q4 += cc * q4; Q5 += cc * q5;
        }
    }

    // Origin shift to the column atom (nu) + traceless transform with the resident S.
    double Rx = xb, Ry = yb, Rz = zb;
    double Smn = S[mn];
    dp_int[0*nn + mn] = D0 - Rx * Smn;
    dp_int[1*nn + mn] = D1 - Ry * Smn;
    dp_int[2*nn + mn] = D2 - Rz * Smn;

    double qxx = Q0 - 2.0lf*Rx*D0 + Rx*Rx*Smn;
    double qxy = Q1 - Rx*D1 - Ry*D0 + Rx*Ry*Smn;
    double qyy = Q2 - 2.0lf*Ry*D1 + Ry*Ry*Smn;
    double qxz = Q3 - Rx*D2 - Rz*D0 + Rx*Rz*Smn;
    double qyz = Q4 - Ry*D2 - Rz*D1 + Ry*Rz*Smn;
    double qzz = Q5 - 2.0lf*Rz*D2 + Rz*Rz*Smn;
    double tr = 0.5lf * (qxx + qyy + qzz);
    qp_int[0*nn + mn] = 1.5lf * qxx - tr;
    qp_int[1*nn + mn] = 1.5lf * qxy;
    qp_int[2*nn + mn] = 1.5lf * qyy - tr;
    qp_int[3*nn + mn] = 1.5lf * qxz;
    qp_int[4*nn + mn] = 1.5lf * qyz;
    qp_int[5*nn + mn] = 1.5lf * qzz - tr;
}
