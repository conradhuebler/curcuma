#version 450
#extension GL_ARB_gpu_shader_fp64 : enable
#extension GL_GOOGLE_include_directive : enable
#include "vk_integrals.glsl"
// Isotropic Coulomb nuclear gradient (Stage 4, section 3). One thread per atom A:
// GATHER over (shell is∈A, shell js∉A) so the force on A is summed without FP64
// atomics. gexp = 2 (gamma = (R² + γ̄⁻²)^(-1/2), dγ/dr/r = -γ³). Verbatim from
// rocm k_grad_coulomb, antisymmetric-pair restructured. Claude Generated (V-AP1).
layout(local_size_x = 64) in;
layout(std430, binding = 0) readonly buffer B0 { int    sh2at[]; };
layout(std430, binding = 1) readonly buffer B1 { double g[]; };       // per-shell hardness
layout(std430, binding = 2) readonly buffer B2 { double q_sh[]; };
layout(std430, binding = 3) readonly buffer B3 { double xyz[]; };
layout(std430, binding = 4)          buffer B4 { double grad[]; };
layout(push_constant) uniform PC { uint nat; uint nsh; uint is_gfn2; } pc;

void main()
{
    uint A = gl_GlobalInvocationID.x;
    if (A >= pc.nat) return;
    double xA = xyz[3*A+0], yA = xyz[3*A+1], zA = xyz[3*A+2];
    double ax = 0.0lf, ay = 0.0lf, az = 0.0lf;
    for (uint is = 0u; is < pc.nsh; ++is) {
        if (uint(sh2at[is]) != A) continue;
        double qi = q_sh[is], gi = g[is];
        for (uint js = 0u; js < pc.nsh; ++js) {
            int jat = sh2at[js];
            if (uint(jat) == A) continue;
            double dx = xA - xyz[3*jat+0], dy = yA - xyz[3*jat+1], dz = zA - xyz[3*jat+2];
            double r2 = dx*dx + dy*dy + dz*dz;
            if (r2 < 1.0e-12lf) continue;
            double gam_bar = coulomb_average(gi, g[js], pc.is_gfn2 != 0u);
            double gamma   = 1.0lf / sqrt(r2 + 1.0lf / (gam_bar * gam_bar));  // (R²+γ̄⁻²)^(-1/2)
            double dgamma_dr = -gamma * gamma * gamma;                        // gexp=2 → -γ³
            double force = qi * q_sh[js] * dgamma_dr;
            ax += force * dx; ay += force * dy; az += force * dz;
        }
    }
    grad[3*A+0] += ax; grad[3*A+1] += ay; grad[3*A+2] += az;
}
