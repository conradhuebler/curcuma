#version 450
#extension GL_ARB_gpu_shader_fp64 : enable
#extension GL_GOOGLE_include_directive : enable
#include "vk_integrals.glsl"
// Coordination numbers: one thread per atom (cutoff 25 bohr). Claude Generated (Stage 3).
layout(local_size_x = 64) in;
layout(std430, binding = 0) readonly  buffer Xb { double xyz[]; };
layout(std430, binding = 1) readonly  buffer Zb { int    z[]; };
layout(std430, binding = 2) readonly  buffer Cb { double covrad[]; };
layout(std430, binding = 3) writeonly buffer Nb { double cn[]; };
layout(push_constant) uniform PC { uint nat; uint is_gfn2; } pc;

void main()
{
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.nat) return;
    double xi = xyz[3*i+0], yi = xyz[3*i+1], zi = xyz[3*i+2];
    double rci = covrad[z[i] - 1];
    double cut2 = 625.0lf;   // 25^2
    double sum = 0.0lf;
    for (uint j = 0u; j < pc.nat; ++j) {
        if (j == i) continue;
        double dx = xi - xyz[3*j+0], dy = yi - xyz[3*j+1], dz = zi - xyz[3*j+2];
        double r2 = dx*dx + dy*dy + dz*dz;
        if (r2 > cut2 || r2 < 1.0e-12lf) continue;
        double r = sqrt(r2);
        double rc = rci + covrad[z[j] - 1];
        sum += cn_pair(r, rc, pc.is_gfn2 != 0u);
    }
    cn[i] = sum;
}
