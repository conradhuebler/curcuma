#version 450
#extension GL_ARB_gpu_shader_fp64 : enable
#extension GL_GOOGLE_include_directive : enable
#include "vk_integrals.glsl"
// Repulsion nuclear gradient (Stage 4, section 1). One thread per atom i: GATHER
// formulation grad[i] = Σ_{j≠i} f_ij (f_ij = -f_ji), so no FP64 atomics are needed
// (Vulkan has no atomicAdd(double)). Verbatim math from rocm k_grad_repulsion; the
// host clears grad before the first kernel, every gradient kernel read-modify-adds
// its own atom slot. Claude Generated (V-AP1).
layout(local_size_x = 64) in;
layout(std430, binding = 0) readonly buffer B0 { int    z[]; };
layout(std430, binding = 1) readonly buffer B1 { double xyz[]; };
layout(std430, binding = 2) readonly buffer B2 { double rep_alpha[]; };
layout(std430, binding = 3) readonly buffer B3 { double rep_zeff[]; };
layout(std430, binding = 4)          buffer B4 { double grad[]; };
layout(push_constant) uniform PC { uint nat; uint nsh; uint is_gfn2; } pc;

void main()
{
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.nat) return;
    int    zi    = z[i];
    double alfi  = rep_alpha[i], zeffi = rep_zeff[i];
    double xi = xyz[3*i+0], yi = xyz[3*i+1], zit = xyz[3*i+2];
    double gx = 0.0lf, gy = 0.0lf, gz = 0.0lf;
    for (uint j = 0u; j < pc.nat; ++j) {
        if (j == i) continue;
        double dx = xi - xyz[3*j+0], dy = yi - xyz[3*j+1], dz = zit - xyz[3*j+2];
        double r2 = dx*dx + dy*dy + dz*dz;
        if (r2 < 1.0e-12lf) continue;
        double r = sqrt(r2);
        double alpha_pair = sqrt(alfi * rep_alpha[j]);
        // kexp_pair = 1.5 (GFN1/GFN2 heavy) or 1.0 (GFN2 H/He pair). rexp = 1 → /r.
        double kexp_pair = 1.5lf, r_kexp, r_kexp_m1;
        if (pc.is_gfn2 != 0u && zi <= 2 && z[j] <= 2) {
            kexp_pair = 1.0lf; r_kexp = r;            r_kexp_m1 = 1.0lf;
        } else {
            r_kexp = r * sqrt(r);                     r_kexp_m1 = sqrt(r);  // r^1.5, r^0.5
        }
        double E_pair = zeffi * rep_zeff[j] / r * dexp(-alpha_pair * r_kexp);
        double dEdr   = -(1.0lf / r + alpha_pair * kexp_pair * r_kexp_m1) * E_pair;
        gx += dEdr * dx / r; gy += dEdr * dy / r; gz += dEdr * dz / r;
    }
    grad[3*i+0] += gx; grad[3*i+1] += gy; grad[3*i+2] += gz;
}
