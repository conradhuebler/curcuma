#version 450
#extension GL_ARB_gpu_shader_fp64 : enable
#extension GL_GOOGLE_include_directive : enable
#include "vk_integrals.glsl"
// D4 EEQ raw coordination number (Stage 5, Part A) — the O(N²) erf sum only:
//   cn_raw_i = Σ_{j≠i} ½(1 + erf(KN·(r-rc_ij)/rc_ij)).
// The O(N) log-compression cn_i = log(1+e^CNMAX) − log(1+e^(CNMAX−raw)) is done on the host
// (GLSL fp64 has no log; cn only feeds the host-side RHS / u-weight). One invocation/atom.
// Claude Generated.
layout(local_size_x = 64) in;
layout(std430, binding = 0) readonly buffer B0 { double xyz[]; };   // 3N
layout(std430, binding = 1) readonly buffer B1 { double rcov[]; };  // N
layout(std430, binding = 2)          buffer B2 { double cn_raw[]; };// N

layout(push_constant) uniform PC { uint N; } pc;

const double KN = -7.5lf;

void main()
{
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.N) return;
    double rci = rcov[i];
    if (rci == 0.0lf) { cn_raw[i] = 0.0lf; return; }
    double xi = xyz[3u*i+0u], yi = xyz[3u*i+1u], zi = xyz[3u*i+2u];
    double raw = 0.0lf;
    for (uint j = 0u; j < pc.N; ++j) {
        if (j == i) continue;
        double rcj = rcov[j];
        if (rcj == 0.0lf) continue;
        double dx = xi - xyz[3u*j+0u], dy = yi - xyz[3u*j+1u], dz = zi - xyz[3u*j+2u];
        double r = sqrt(dx*dx + dy*dy + dz*dz);
        double rcij = rci + rcj;
        double dr = (r - rcij) / rcij;
        raw += 0.5lf * (1.0lf + derf(KN * dr));
    }
    cn_raw[i] = raw;
}
