#version 450
// EIG-3 Cuppen divide-and-conquer, merge step 1: solve the secular equation
//   1 + rho·Σ_i z_i²/(D_i − λ) = 0
// for the rank-1 update diag(D) + rho·z·zᵀ (rho>0, D strictly ascending, z all
// non-negligible — the deflated secular set). One root per gap (D_j, D_{j+1}) plus one in
// (D_{k-1}, D_{k-1}+rho·‖z‖²), found by bisection on the shift τ anchored at the nearer pole
// (the dlaed4 trick). Writes lam[j] and the ACCURATE denominators dml(i,j) = (D_i−origin)−τ
// (column-major ksz×ksz) — never recomputed by subtraction, so the small-denominator relative
// precision the eigenvectors need is preserved.
//
// ONE THREAD per root j: serial bisection + serial O(ksz) rational-sum evaluation, no shared
// memory and no barriers (roots are independent). A verbatim port of the secularSolve roots
// loop in native_eigensolver.cpp. Claude Generated (EIG-3).
layout(local_size_x = 64) in;
layout(std430, binding = 0) readonly  buffer Db { double D[]; };     // ksz, ascending poles
layout(std430, binding = 1) readonly  buffer Zb { double zw[]; };    // ksz, normalized weights
layout(std430, binding = 2) readonly  buffer Rb { double rpar[]; };  // [0]=rho (>0), [1]=‖z‖²
layout(std430, binding = 3) writeonly buffer Lb { double lam[]; };   // ksz roots
layout(std430, binding = 4) writeonly buffer Mb { double dml[]; };   // ksz×ksz, col-major
layout(push_constant) uniform PC { uint k; } pc;

void main()
{
    uint j = gl_GlobalInvocationID.x;
    uint k = pc.k;
    if (j >= k) return;
    double rho = rpar[0], znorm2 = rpar[1];

    // f increases on (left,right) from −∞ to +∞; pick the nearer pole as origin.
    double left  = D[j];
    double right = (j < k - 1u) ? D[j + 1u] : (D[k - 1u] + rho * znorm2);
    double mid   = 0.5lf * (left + right);
    double fmid  = 1.0lf;
    for (uint i = 0u; i < k; ++i) fmid += rho * zw[i] * zw[i] / (D[i] - mid);
    double origin = (j < k - 1u && fmid < 0.0lf) ? D[j + 1u] : D[j];

    // Solve h(τ) = 1 + rho·Σ z_i²/((D_i−origin)−τ) = 0 for τ = λ−origin by bisection to full
    // fp resolution (τ pinned between adjacent floats terminates the loop).
    double a = left - origin, b = right - origin;
    double tau = 0.5lf * (a + b);
    for (int it = 0; it < 200; ++it) {
        double t = 0.5lf * (a + b);
        if (t <= a || t >= b) break;           // fp resolution reached
        double h = 1.0lf;
        for (uint i = 0u; i < k; ++i) h += rho * zw[i] * zw[i] / ((D[i] - origin) - t);
        if (h < 0.0lf) a = t; else b = t;
        tau = t;
    }
    lam[j] = origin + tau;
    for (uint i = 0u; i < k; ++i) dml[i + j * k] = (D[i] - origin) - tau;   // D_i − λ_j (accurate)
}
